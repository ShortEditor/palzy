rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────
    match /users/{uid} {
      // Any logged-in user can read any profile
      allow read: if request.auth != null;
      // Only the owner can write their profile
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Posts ────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if request.auth != null;

      // Any logged-in user can create a post
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 500;

      // Only the author can delete their post
      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;

      // Only allow updates to likeCount and commentCount (denormalized counters)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['likeCount', 'commentCount']);
    }

    // ── Comments ─────────────────────────────────────────────
    match /posts/{postId}/comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 500;
    }

    // ── Likes ────────────────────────────────────────────────
    match /likes/{likeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        // likeId format: {postId}_{uid} — uid must match the logged-in user
        && (likeId.split('_')[1] == request.auth.uid
            || resource == null);  // allow delete
    }
  }
}
