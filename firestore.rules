rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────
    function isAuth()    { return request.auth != null; }
    function uid()       { return request.auth.uid; }
    function isAdmin()   {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(uid())).data.isAdmin == true;
    }
    function isBanned() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(uid())).data.get('banned', false) == true;
    }

    // ─── Users ────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();

      // Anyone can create their own doc (first login)
      allow create: if isAuth() && uid() == userId;

      // Owner can update own doc — but NOT isAdmin/isVerified/banned
      allow update: if isAuth() && uid() == userId
        && !('isAdmin'    in request.resource.data.diff(resource.data).affectedKeys())
        && !('isVerified' in request.resource.data.diff(resource.data).affectedKeys())
        && !('banned'     in request.resource.data.diff(resource.data).affectedKeys());

      // Any logged-in user can update follower/following counters (needed for follow system)
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['followerCount', 'followingCount']);

      // Admin can update anything
      allow update: if isAdmin();
    }

    // ─── Posts ────────────────────────────────────────────────
    match /posts/{postId} {
      allow read:   if isAuth();
      allow create: if isAuth() && !isBanned()
        && request.resource.data.authorId == uid();
      allow delete: if isAuth()
        && (resource.data.authorId == uid() || isAdmin());
      // Only allow updating specific counter fields
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['likeCount', 'commentCount']);

      // ─── Comments (subcollection) ────────────────────────
      match /comments/{commentId} {
        allow read:   if isAuth();
        allow create: if isAuth() && !isBanned()
          && request.resource.data.authorId == uid()
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow delete: if isAuth()
          && (resource.data.authorId == uid() || isAdmin());
      }
    }

    // ─── Likes ────────────────────────────────────────────────
    match /likes/{likeId} {
      allow read, write: if isAuth();
    }

    // ─── Follows ──────────────────────────────────────────────
    match /follows/{followId} {
      allow read, write: if isAuth();
    }

    // ─── Reports ──────────────────────────────────────────────
    match /reports/{reportId} {
      allow read:   if isAdmin();
      allow create: if isAuth() && !isBanned();
      allow update: if isAdmin();
    }
  }
}
