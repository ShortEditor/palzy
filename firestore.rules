rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function isLoggedIn()      { return request.auth != null; }
    function isOwner(uid)      { return request.auth.uid == uid; }
    function isBanned()        {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.banned == true;
    }

    // ── Users ────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isLoggedIn();
      // Only owner can write their own profile, but isAdmin & isVerified only via Admin SDK
      allow write: if isLoggedIn() && isOwner(uid)
        && !('isAdmin'    in request.resource.data)
        && !('isVerified' in request.resource.data)
        && !('banned'     in request.resource.data);
      // Admins can write anything to any user doc
      allow write: if isLoggedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ── Posts ────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if isLoggedIn();

      allow create: if isLoggedIn()
        && !isBanned()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 500;

      allow delete: if isLoggedIn()
        && (resource.data.authorId == request.auth.uid
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);

      allow update: if isLoggedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['likeCount', 'commentCount']);
    }

    // ── Comments ─────────────────────────────────────────────
    match /posts/{postId}/comments/{commentId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn() && !isBanned()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 500;
    }

    // ── Likes ────────────────────────────────────────────────
    match /likes/{likeId} {
      allow read:   if isLoggedIn();
      allow write:  if isLoggedIn();
    }

    // ── Reports ──────────────────────────────────────────────
    match /reports/{reportId} {
      allow read:   if isLoggedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
      allow create: if isLoggedIn() && !isBanned();
      allow update: if isLoggedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
